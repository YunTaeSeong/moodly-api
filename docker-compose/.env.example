# =============================================================================
# Moodly Docker Compose 환경 변수 템플릿
# 사용법: cp .env.example .env 후 값 수정
# =============================================================================

COMPOSE_PROJECT_NAME=moodly

# -----------------------------------------------------------------------------
# MySQL (모든 DB 컨테이너 공통)
# -----------------------------------------------------------------------------
MYSQL_ROOT_PASSWORD=change-me

# 애플리케이션 DB 접속 (대부분 root 사용)
DB_USERNAME=root
DB_PASSWORD=change-me

# -----------------------------------------------------------------------------
# JWT (Gateway + 모든 마이크로서비스 동일 값 필수)
# -----------------------------------------------------------------------------
JWT_SECRET=change-me-to-long-random-string
JWT_ACCESS_TOKEN=900
JWT_REFRESH_TOKEN=604800

# -----------------------------------------------------------------------------
# 카카오 OAuth (auth-service)
# -----------------------------------------------------------------------------
KAKAO_CLIENT_ID=your_kakao_rest_api_key
KAKAO_CLIENT_SECRET=your_kakao_client_secret
KAKAO_REDIRECT_URI=http://localhost:3000/auth/kakao/callback

# -----------------------------------------------------------------------------
# 네이버 메일 (user-service — 아이디/비밀번호 찾기)
# 네이버 로그인 비밀번호가 아닌 "앱 비밀번호" 사용
# 주의: KEY=value 형식 (=). KEY: value 는 Docker에서 동작하지 않음
# -----------------------------------------------------------------------------
NAVER_MAIL_USERNAME=your_id@naver.com
NAVER_MAIL_PASSWORD=your_naver_app_password

# -----------------------------------------------------------------------------
# 토스페이먼츠 (payment-service)
# -----------------------------------------------------------------------------
TOSS_SECRET_KEY=test_sk_your_toss_secret_key

# -----------------------------------------------------------------------------
# Kafka (product-service, notification-service)
# Kafka 없이 인프라만 띄울 때: false
# -----------------------------------------------------------------------------
KAFKA_ENABLED=true

# -----------------------------------------------------------------------------
# 프론트엔드 참고용 (docker-compose에서는 user-service에 주입됨)
# moodly-web/.env 에도 동일하게 설정
# -----------------------------------------------------------------------------
APP_FRONTEND_BASE_URL=http://localhost:3000

# moodly-web 전용 (백엔드 compose에서는 미사용, 문서용)
# PORT=3000
# REACT_APP_KAKAO_CLIENT_ID=your_kakao_rest_api_key
# REACT_APP_KAKAO_REDIRECT_URI=http://localhost:3000/auth/kakao/callback
